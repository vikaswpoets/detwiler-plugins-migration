{
  "key": "group_event_details",
  "title": "Event Details",
  "fields": [
    {
      "key": "field_event_location",
      "label": "Location",
      "name": "event_location",
      "type": "text",
      "instructions": "Enter the location of the event",
      "required": 1,
      "placeholder": "e.g. Conference Center, Virtual, etc."
    },
    {
      "key": "field_event_date",
      "label": "Event Date",
      "name": "event_date",
      "type": "date_picker",
      "instructions": "Select the primary date of the event",
      "required": 1,
      "display_format": "F j, Y",
      "return_format": "Y-m-d",
      "first_day": 1
    },
    {
      "key": "field_event_start_time",
      "label": "Start Time",
      "name": "event_start_time",
      "type": "time_picker",
      "instructions": "Select the start time of the event",
      "required": 1,
      "display_format": "g:i a",
      "return_format": "H:i"
    },
    {
      "key": "field_event_end_time",
      "label": "End Time",
      "name": "event_end_time",
      "type": "time_picker",
      "instructions": "Select the end time of the event",
      "required": 1,
      "display_format": "g:i a",
      "return_format": "H:i"
    }
  ],
  "location": [
    [
      {
        "param": "post_type",
        "operator": "==",
        "value": "event"
      }
    ]
  ],
  "menu_order": 0,
  "position": "normal",
  "style": "default",
  "label_placement": "top",
  "instruction_placement": "label",
  "hide_on_screen": "",
  "active": true,
  "description": "Essential details for events"
